@page "/servers/add"
@inject NavigationManager NavigationManager

<h3>CreateServer</h3>
<EditForm Model="server" OnValidSubmit="HandleSubmit" FormName="CreateServerForm">
    <!--Add Validation-->
    <DataAnnotationsValidator/>
    <ValidationSummary/>

    <div class="mb-3">
        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="server.Name" class="form-control"/>
            <ValidationMessage For="() => server.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label">City</label>
            <InputText @bind-Value="server.City" class="form-control"/>
            <ValidationMessage For="() => server.City"/>
        </div>

        <div class="mb-3">
            <InputCheckbox @bind-Value="server.IsOnline" class="form-check-input" />
            <label class="form-check-label">Online</label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/servers" class="btn btn-secondary">Cancel</a>

</EditForm>


@code {

    //Binds the data from the HTTP post request to the server property
    [SupplyParameterFromForm(FormName = "CreateServerForm")]
    public Server? server { get; set; } = new();

    private void HandleSubmit()
    {
        if(server is not null)
            ServersRepository.AddServer(server);

        NavigationManager.NavigateTo("/servers");
    }
}
