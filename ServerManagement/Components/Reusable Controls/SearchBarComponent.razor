
<div class="mb-3">
    <input type="text"
           class="form-control input-width"
           placeholder="Search server by name..."
           @bind="SearchFilter"
           @bind:event="oninput"
           @bind:after="SendSearchFilter" />
</div>


@code {

    //Parameters: Parent controls their value
    [Parameter]
    public EventCallback<string> OnSearchFilter { get; set; }
    [Parameter]
    public string? SearchFilter { get; set; }

    private async Task SendSearchFilter()
    {
        await OnSearchFilter.InvokeAsync(SearchFilter);
    }

}
